{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "runDateRequired",
      "type": "promptString",
      "description": "Backfill date (YYYY-MM-DD) — REQUIRED for backfill tasks",
      "default": ""
    },
    {
      "id": "gameId",
      "type": "promptString",
      "description": "NCAA gameID (example: 6502232)",
      "default": ""
    }
  ],
  "tasks": [
    {
      "label": "NCAAM: TODAY Pregame (prep + download baseline PBP + list slate)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "NCAAM: TODAY Prep slate + selected_games + last4",
        "NCAAM: TODAY Download baseline PBP (workers=8,max-rps=4)",
        "NCAAM: TODAY List slate (gameID | away @ home)"
      ],
      "problemMatcher": []
    },
    {
      "label": "NCAAM: TODAY Prep slate + selected_games + last4",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\Scripts\\vscode_task_runner.ps1",
        "-Action",
        "prep"
      ],
      "problemMatcher": [],
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "NCAAM: TODAY Download baseline PBP (workers=8,max-rps=4)",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\Scripts\\vscode_task_runner.ps1",
        "-Action",
        "download_pbp"
      ],
      "problemMatcher": [],
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "NCAAM: TODAY List slate (gameID | away @ home)",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\Scripts\\vscode_task_runner.ps1",
        "-Action",
        "list_slate"
      ],
      "problemMatcher": [],
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "NCAAM: TODAY Halftime run (pull + report + log) [WRITES EXCEL]",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\Scripts\\vscode_task_runner.ps1",
        "-Action",
        "halftime_run",
        "-GameId",
        "${input:gameId}"
      ],
      "problemMatcher": [],
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "NCAAM: Postgame update (ONLY missing results) [WRITES EXCEL]",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\Scripts\\vscode_task_runner.ps1",
        "-Action",
        "postgame_missing"
      ],
      "problemMatcher": [],
      "options": { "cwd": "${workspaceFolder}" }
    },

    {
      "label": "NCAAM: BACKFILL Pregame (prep + download baseline PBP + list slate)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "NCAAM: BACKFILL Prep slate + selected_games + last4 (requires date)",
        "NCAAM: BACKFILL Download baseline PBP (requires date)",
        "NCAAM: BACKFILL List slate (requires date)"
      ],
      "problemMatcher": []
    },
    {
      "label": "NCAAM: BACKFILL Prep slate + selected_games + last4 (requires date)",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\Scripts\\vscode_task_runner.ps1",
        "-Action",
        "prep",
        "-Date",
        "${input:runDateRequired}"
      ],
      "problemMatcher": [],
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "NCAAM: BACKFILL Download baseline PBP (requires date)",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\Scripts\\vscode_task_runner.ps1",
        "-Action",
        "download_pbp",
        "-Date",
        "${input:runDateRequired}"
      ],
      "problemMatcher": [],
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "NCAAM: BACKFILL List slate (requires date)",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\Scripts\\vscode_task_runner.ps1",
        "-Action",
        "list_slate",
        "-Date",
        "${input:runDateRequired}"
      ],
      "problemMatcher": [],
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "NCAAM: BACKFILL Halftime run (pull + report + log) [WRITES EXCEL] (requires date)",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\Scripts\\vscode_task_runner.ps1",
        "-Action",
        "halftime_run",
        "-Date",
        "${input:runDateRequired}",
        "-GameId",
        "${input:gameId}"
      ],
      "problemMatcher": [],
      "options": { "cwd": "${workspaceFolder}" }
    }
  ]
}
``