{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "gameId",
      "type": "promptString",
      "description": "NCAA gameID (example: 6534635)"
    }
  ],
  "tasks": [
    {
      "label": "NCAAM: TODAY Pregame (prep + download baseline PBP + list slate)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "NCAAM: TODAY Prep slate + selected_games + last4",
        "NCAAM: TODAY Download baseline PBP (workers=8,max-rps=4)",
        "NCAAM: TODAY List slate (gameID | away @ home)"
      ],
      "problemMatcher": []
    },
    {
      "label": "NCAAM: TODAY Prep slate + selected_games + last4",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\Scripts\\vscode_task_runner.ps1",
        "-Action",
        "prep"
      ],
      "problemMatcher": [],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared", "clear": false }
    },
    {
      "label": "NCAAM: TODAY Download baseline PBP (workers=8,max-rps=4)",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\Scripts\\vscode_task_runner.ps1",
        "-Action",
        "download_pbp"
      ],
      "problemMatcher": [],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared", "clear": false }
    },
    {
      "label": "NCAAM: TODAY List slate (gameID | away @ home)",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\Scripts\\vscode_task_runner.ps1",
        "-Action",
        "list_slate"
      ],
      "problemMatcher": [],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared", "clear": false }
    },
    {
      "label": "NCAAM: TODAY Halftime run (pull + report + log) [WRITES EXCEL]",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\Scripts\\vscode_task_runner.ps1",
        "-Action",
        "halftime_run",
        "-GameId",
        "${input:gameId}"
      ],
      "problemMatcher": [],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared", "clear": false }
    },
    {
      "label": "NCAAM: TODAY Postgame update (ONLY missing results) [WRITES EXCEL]",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\Scripts\\vscode_task_runner.ps1",
        "-Action",
        "postgame_missing"
      ],
      "problemMatcher": [],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared", "clear": false }
    }
  ]
}